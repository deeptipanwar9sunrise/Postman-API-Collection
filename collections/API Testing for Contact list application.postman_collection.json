  "item": [
    {
      "name": "Add New User",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 201\",  ()=> {\r",
              "pm.response.to.have.status(201);\r",
              "})\r",
              "\r",
              "let resdata = pm.response.json();\r",
              "pm.test(\"Response JSON has a non-empty token\", () => {\r",
              "    // Reuse parsed response if it exists\r",
              "    const data = (typeof resdata !== 'undefined') ? resdata : pm.response.json();\r",
              "    pm.expect(data).to.have.property('token');\r",
              "    pm.expect(data.token).to.be.a('string').and.not.be.empty;\r",
              "});\r",
              "\r",
              "let tokenvar = resdata.token;\r",
              "console.log(\"Token generated is:\", tokenvar);\r",
              "pm.environment.set(\"token\", tokenvar);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// Generate a unique, valid email address for each run\r",
              "const timestamp = Date.now();\r",
              "const randInt = pm.variables.replaceIn('{{$randomInt}}');\r",
              "const dynamicEmail = `user+${timestamp}_${randInt}@gmail.com`;\r",
              "\r",
              "pm.environment.set('email', dynamicEmail);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"firstName\": \"Test\",\r\n    \"lastName\": \"User\",\r\n    \"email\": \"{{email}}\",\r\n    \"password\": \"myPassword\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseURL}}/users",
          "host": [
            "{{baseURL}}"
          ],
          "path": [
            "users"
          ]
        }
      },
      "response": []
    },
